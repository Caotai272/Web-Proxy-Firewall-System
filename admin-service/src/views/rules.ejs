<%- include('partials-header', { title: 'Rules' }) %>
<section class="page-head">
  <h2>Rules</h2>
  <p class="lead">Current allow and block rules that drive the request-stage filtering pipeline.</p>
</section>
<section class="card form-card">
  <div class="panel-head">
    <div>
      <p class="kicker">Admin Control</p>
      <h3>Add Rule</h3>
      <p class="table-note">Create a domain or URL pattern rule. The proxy reads active rules directly from PostgreSQL on each request.</p>
    </div>
  </div>
  <form method="post" action="/rules" class="admin-form grid-3">
    <label>
      <span>Type</span>
      <select name="type" required>
        <option value="domain">domain</option>
        <option value="url_pattern">url_pattern</option>
      </select>
    </label>
    <label>
      <span>Action</span>
      <select name="action" required>
        <option value="block">block</option>
        <option value="allow">allow</option>
      </select>
    </label>
    <label>
      <span>Priority</span>
      <input type="number" name="priority" min="1" max="10000" value="100" required />
    </label>
    <label>
      <span>Target</span>
      <input type="text" name="target" placeholder="facebook.com or /download/" required />
    </label>
    <label>
      <span>Scope Type</span>
      <select name="scope_type">
        <option value="global">global</option>
        <option value="request_domain">request_domain</option>
        <option value="client_ip">client_ip</option>
      </select>
    </label>
    <label>
      <span>Scope Value</span>
      <input type="text" name="scope_value" placeholder="Optional scope target" />
    </label>
    <label class="field-span-3">
      <span>Description</span>
      <input type="text" name="description" placeholder="Why this rule exists" />
    </label>
    <div class="field-span-3 action-row">
      <button type="submit">Create rule</button>
    </div>
  </form>
</section>
<section class="card table-card">
  <div class="panel-head">
    <div>
      <p class="kicker">Database Rules</p>
      <h3>Structured Rule Set</h3>
      <p class="table-note">These entries are loaded by the proxy before it evaluates each request.</p>
    </div>
  </div>
  <div class="table-scroller">
    <table class="table-main">
      <thead>
        <tr>
          <th>Rule</th>
          <th>Type</th>
          <th>Action</th>
          <th>Priority</th>
          <th>Scope</th>
          <th>Hits</th>
          <th>Last matched</th>
          <th>Status</th>
          <th>Control</th>
        </tr>
      </thead>
      <tbody>
        <% rules.forEach((rule) => { %>
          <tr>
            <td>
              <div class="cell-title">
                <strong class="mono"><%= rule.target %></strong>
                <span class="cell-meta">Rule #<%= rule.id %></span>
              </div>
            </td>
            <td><%= rule.type %></td>
            <td><span class="status-badge <%= rule.action %>"><%= rule.action %></span></td>
            <td><span class="mono"><%= rule.priority %></span></td>
            <td><%= rule.scope_type %><%= rule.scope_value ? `:${rule.scope_value}` : '' %></td>
            <td><%= rule.hit_count %></td>
            <td><%= formatVietnamDateTime(rule.last_matched_at) %></td>
            <td><span class="status-badge <%= rule.is_active ? 'active' : 'inactive' %>"><%= rule.is_active ? 'active' : 'inactive' %></span></td>
            <td>
              <div class="inline-actions">
                <form method="post" action="/rules/<%= rule.id %>/toggle" class="inline-form">
                  <button type="submit" class="button-link secondary"><%= rule.is_active ? 'Disable' : 'Enable' %></button>
                </form>
                <form method="post" action="/rules/<%= rule.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this rule?');">
                  <button type="submit" class="button-link danger">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials-footer') %>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <div class="topbar-inner">
          <a class="brand" href="/dashboard">
            <span class="brand-mark">WF</span>
            <span>
              <strong>Web Proxy Firewall</strong>
              <small>Admin Console</small>
            </span>
          </a>
          <nav class="nav">
            <a href="/dashboard">Dashboard</a>
            <a href="/logs">Logs</a>
            <a href="/filter-lab">Filter Lab</a>
            <% if (currentUser && currentUser.role === 'admin') { %>
              <a href="/rules">Rules</a>
              <a href="/keywords">Keywords</a>
              <a href="/extensions">Extensions</a>
            <% } %>
          </nav>
          <div class="topbar-actions">
            <% if (currentUser) { %>
              <div class="session-meta">
                <strong><%= currentUser.displayName %></strong>
                <span><%= currentUser.role %> - <%= currentUser.email %></span>
              </div>
              <form method="post" action="/logout" class="logout-form">
                <button type="submit" class="button-link secondary">Log out</button>
              </form>
            <% } %>
            <button
              type="button"
              class="theme-toggle"
              data-theme-toggle
              aria-label="Toggle dark mode"
              aria-pressed="false"
            >
              <span class="theme-toggle-chip" aria-hidden="true"></span>
              <span class="theme-toggle-label">Dark mode</span>
            </button>
          </div>
        </div>
      </header>
      <main class="content">
        <div class="content-inner">
          <% if (flashSuccess || flashError) { %>
            <section class="flash-stack">
              <% if (flashSuccess) { %>
                <div class="flash flash-success"><%= flashSuccess %></div>
              <% } %>
              <% if (flashError) { %>
                <div class="flash flash-error"><%= flashError %></div>
              <% } %>
            </section>
          <% } %>

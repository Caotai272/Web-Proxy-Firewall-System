<%- include('partials-header', { title: 'Logs' }) %>
<section class="page-head">
  <h2>Access Logs</h2>
  <p class="lead">Search and inspect proxy decisions, upstream metadata, and latency directly from the database.</p>
</section>

<section class="card filter-card">
  <div class="panel-head">
    <div>
      <p class="kicker">Query Builder</p>
      <h3>Filter Log Stream</h3>
      <p>Scope the dataset by decision, method, domain, or matched rule text.</p>
    </div>
  </div>
  <form class="filter-form" method="GET" action="/logs">
    <label>
      <span>Decision</span>
      <select name="decision">
        <option value="">All</option>
        <option value="allow" <%= filters.decision === 'allow' ? 'selected' : '' %>>Allow</option>
        <option value="block" <%= filters.decision === 'block' ? 'selected' : '' %>>Block</option>
      </select>
    </label>
    <label>
      <span>Method</span>
      <select name="method">
        <option value="">All</option>
        <option value="GET" <%= filters.method === 'GET' ? 'selected' : '' %>>GET</option>
        <option value="POST" <%= filters.method === 'POST' ? 'selected' : '' %>>POST</option>
        <option value="CONNECT" <%= filters.method === 'CONNECT' ? 'selected' : '' %>>CONNECT</option>
      </select>
    </label>
    <label>
      <span>Domain</span>
      <input type="text" name="domain" value="<%= filters.domain %>" placeholder="facebook.com" />
    </label>
    <label>
      <span>Search</span>
      <input type="text" name="query" value="<%= filters.query %>" placeholder="matched rule or URL" />
    </label>
    <label>
      <span>Limit</span>
      <input type="number" min="1" max="200" name="limit" value="<%= filters.limit %>" />
    </label>
    <button type="submit">Apply filters</button>
  </form>
</section>

<section class="metrics compact-metrics">
  <article class="card">
    <span>Total Logs</span>
    <strong><%= summary.overview.total_logs %></strong>
  </article>
  <article class="card">
    <span>Blocked</span>
    <strong><%= summary.overview.block_logs %></strong>
  </article>
  <article class="card">
    <span>Allowed</span>
    <strong><%= summary.overview.allow_logs %></strong>
  </article>
  <article class="card">
    <span>Avg Latency</span>
    <strong><%= summary.overview.avg_latency_ms %> ms</strong>
  </article>
</section>

<section class="card table-card">
  <div class="panel-head">
    <div>
      <p class="kicker">Recent Rows</p>
      <h3>Structured Access Log</h3>
      <p class="table-note">Each row reflects the final proxy decision stored in PostgreSQL, including stage, upstream response, extension detection, and latency.</p>
    </div>
  </div>
  <div class="table-scroller">
    <table class="table-main">
      <thead>
        <tr>
          <th>Request</th>
          <th>Decision</th>
          <th>Stage</th>
          <th>Status</th>
          <th>Extension</th>
          <th>Latency</th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach((item) => { %>
          <tr>
            <td>
              <div class="cell-title">
                <strong><%= item.domain || 'unknown-domain' %></strong>
                <span class="cell-meta mono"><%= item.request_method %> <%= item.url %></span>
                <span class="cell-meta">Logged at <%= item.created_at %></span>
              </div>
            </td>
            <td>
              <span class="status-badge <%= item.decision %>"><%= item.decision %></span>
              <div class="cell-meta"><%= item.matched_rule || 'no matched rule' %></div>
            </td>
            <td><%= item.rule_stage || '-' %></td>
            <td>
              <div class="cell-title">
                <strong><%= item.status_code %></strong>
                <span class="cell-meta">Upstream: <%= item.upstream_status || '-' %></span>
              </div>
            </td>
            <td><%= item.detected_extension || '-' %></td>
            <td><%= item.latency_ms || 0 %> ms</td>
          </tr>
        <% }) %>
        <% if (logs.length === 0) { %>
          <tr>
            <td colspan="6">No logs match the current filters.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials-footer') %>

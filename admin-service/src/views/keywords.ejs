<%- include('partials-header', { title: 'Keywords' }) %>
<section class="page-head">
  <h2>Keywords</h2>
</section>
<section class="card table-card">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Keyword</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <% keywords.forEach((item) => { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.keyword %></td>
          <td><%= item.description %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('partials-footer') %>
